#include <iostream>
#include <iomanip>
#include <stdexcept>

// ====================== –С–Р–Ч–Ю–Т–Ш–Щ –Ъ–Ы–Р–° ======================
class Matrix {
protected:
    int rows;
    int cols;
    int** a;

    void allocate(int r, int c) {
        rows = r;
        cols = c;
        a = new int*[rows];
        for (int i = 0; i < rows; ++i)
            a[i] = new int[cols]{0};
    }

public:
    // –Ъ–Њ–љ—Б—В—А—Г–Ї—В–Њ—А –Ј–∞ –Ј–∞–Љ–Њ–≤—З—Г–≤–∞–љ–љ—П–Љ
    Matrix() : rows(0), cols(0), a(nullptr) {}

    // –Ъ–Њ–љ—Б—В—А—Г–Ї—В–Њ—А –Ј –њ–∞—А–∞–Љ–µ—В—А–∞–Љ–Є
    Matrix(int r, int c) : rows(0), cols(0), a(nullptr) {
        if (r <= 0 || c <= 0) throw std::invalid_argument("Wrong size");
        allocate(r, c);
    }

    // –Ъ–Њ–љ—Б—В—А—Г–Ї—В–Њ—А –Ї–Њ–њ—Ц—О–≤–∞–љ–љ—П
    Matrix(const Matrix& other) : rows(0), cols(0), a(nullptr) {
        if (other.a == nullptr) return;
        allocate(other.rows, other.cols);
        for (int i = 0; i < rows; ++i)
            for (int j = 0; j < cols; ++j)
                a[i][j] = other.a[i][j];
    }

    // –Ю–њ–µ—А–∞—В–Њ—А –њ—А–Є—Б–≤–Њ—Ф–љ–љ—П
    Matrix& operator=(const Matrix& other) {
        if (this == &other) return *this;

        clear();

        if (other.a == nullptr) return *this;

        allocate(other.rows, other.cols);
        for (int i = 0; i < rows; ++i)
            for (int j = 0; j < cols; ++j)
                a[i][j] = other.a[i][j];

        return *this;
    }

    // –Ф–µ—Б—В—А—Г–Ї—В–Њ—А
    virtual ~Matrix() {
        clear();
    }

    // –Ч–∞–њ–Є—Б –µ–ї–µ–Љ–µ–љ—В–∞
    virtual void set(int i, int j, int value) {
        if (i < 0в†µв†Їв†Яв†Їв†Юв†Юв†µв†Їв†Їв†Юв†Яв†Юв†Їj < 0 || j >= cols)
            throw std::out_of_range("Index out of range");
        a[i][j] = value;
    }

    // –Ю–і–µ—А–ґ–∞–љ–љ—П –µ–ї–µ–Љ–µ–љ—В–∞
    virtual int get(int i, int j) const {
        if (i < 0в†Їв†µв†µв†Юв†Їв†Юв†Їв†Яв†µв†Яв†µв†Яв†Юj < 0 || j >= cols)
            throw std::out_of_range("Index out of range");
        return a[i][j];
    }

    // –Т–Є–≤–µ–і–µ–љ–љ—П –Љ–∞—В—А–Є—Ж—Ц
    virtual void print() const {
        if (!a) {
            std::cout << "(empty)\n";
            return;
        }
        for (int i = 0; i < rows; ++i) {
            for (int j = 0; j < cols; ++j)
                std::cout << std::setw(5) << a[i][j];
            std::cout << "\n";
        }
    }

    // –Я–Њ—И—Г–Ї –µ–ї–µ–Љ–µ–љ—В–∞
    bool find(int value, int& outI, int& outJ) const {
        for (int i = 0; i < rows; ++i)
            for (int j = 0; j < cols; ++j)
                if (a[i][j] == value) {
                    outI = i; outJ = j;
                    return true;
                }
        return false;
    }

    // –Ж–љ—Д–Њ—А–Љ–∞—Ж—Ц—П –њ—А–Њ –њ–Њ—В–Њ—З–љ—Ц —А–Њ–Ј–Љ—Ц—А–Є
    void info() const {
        std::cout << "Matrix size: " << rows << " x " << cols << "\n";
    }

    // –Ю—З–Є—Й–µ–љ–љ—П –Љ–∞—В—А–Є—Ж—Ц
    virtual void clear() {
        if (!a) { rows = cols = 0; return; }
        for (int i = 0; i < rows; ++i) delete[] a[i];
        delete[] a;
        a = nullptr;
        rows = cols = 0;
    }
};

// ====================== –Я–Ю–•–Ж–Ф–Э–Ш–Щ –Ъ–Ы–Р–° ======================
// –Ь–∞—В—А–Є—Ж—П –Ј –і–Њ–≤—Ц–ї—М–љ–Є–Љ–Є –Љ–µ–ґ–∞–Љ–Є (–≤–Ї–ї—О—З–∞—О—З–Є –≤—Ц–івАЩ—Ф–Љ–љ—Ц)
class BoundedMatrix : public Matrix {
private:
    int rLow, rHigh;
    int cLow, cHigh;

    int ri(int r) const { return r - rLow; }
    int ci(int c) const { return c - cLow; }

    void check(int r, int c) const {
        if (r < rLowв†Їв†Яв†Їв†µв†Яв†Юв†Юв†Юв†Яв†µв†µв†µв†Їc < cLow || c > cHigh)
            throw std::out_of_range("Bounded index out of range");
    }

public:
    // –Ъ–Њ–љ—Б—В—А—Г–Ї—В–Њ—А –Ј–∞ –Ј–∞–Љ–Њ–≤—З—Г–≤–∞–љ–љ—П–Љ
    BoundedMatrix() : Matrix(), rLow(0), rHigh(-1), cLow(0), cHigh(-1) {}

    // –Ъ–Њ–љ—Б—В—А—Г–Ї—В–Њ—А –Ј –Љ–µ–ґ–∞–Љ–Є
    BoundedMatrix(int rowLow, int rowHigh, int colLow, int colHigh)
        : Matrix(), rLow(rowLow), rHigh(rowHigh), cLow(colLow), cHigh(colHigh) {

        if (rowHigh < rowLow || colHigh < colLow)
            throw std::invalid_argument("Wrong bounds");

        int rCount = rowHigh - rowLow + 1;
        int cCount = colHigh - colLow + 1;
        allocate(rCount, cCount);
    }

    // –Ъ–Њ–љ—Б—В—А—Г–Ї—В–Њ—А –Ї–Њ–њ—Ц—О–≤–∞–љ–љ—П
    BoundedMatrix(const BoundedMatrix& other)
        : Matrix(other), rLow(other.rLow), rHigh(other.rHigh),
          cLow(other.cLow), cHigh(other.cHigh) {}

    // –Ч–∞–њ–Є—Б/–Њ–і–µ—А–ґ–∞–љ–љ—П –Ј вАЬ—А–µ–∞–ї—М–љ–Є–Љ–ЄвАЭ —Ц–љ–і–µ–Ї—Б–∞–Љ–Є
    void set(int r, int c, int value) override {
        check(r, c);
        Matrix::set(ri(r), ci(c), value);
    }

    int get(int r, int c) const override {
        check(r, c);
        return Matrix::get(ri(r), ci(c));
    }

    void boundsInfo() const {
        std::cout << "Row bounds: [" << rLow << ".." << rHigh << "], "
                  << "Col bounds: [" << cLow << ".." << cHigh << "]\n";
        info();
    }
};

// ====================== –У–Ю–Ы–Ю–Т–Э–Р –§–£–Э–Ъ–¶–Ж–ѓ ======================
int main() {
    try {
        std::cout << "=== Base matrix ===\n";
        Matrix m(3, 4);
        m.set(0, 0, 10);
        m.set(1, 2, 25);
        m.set(2, 3, -7);
        m.print();
        m.info();

        int i, j;
        if (m.find(25, i, j))
            std::cout << "Found 25 at: (" << i << ", " << j << ")\n";

        std::cout << "\n=== Bounded matrix (negative bounds) ===\n";
        BoundedMatrix bm(-2, 1, 5, 7);   // —А—П–і–Ї–Є -2..1, —Б—В–Њ–≤–њ—Ж—Ц 5..7
        bm.boundsInfo();

        bm.set(-2, 5, 111);
        bm.set(0, 6, 222);
        bm.set(1, 7, 333);

        bm.print();
        std::cout << "bm.get(0,6) = " << bm.get(0, 6) << "\n";

    } catch (const std::exception& e) {
    
        std::cerr << "ERROR: " << e.what() << "\n";
    }
    return 0;
}